# ============================================
# OLTC320 Configuration File
# ============================================
#
# NOTE: OLT connection settings (host, port, username, password)
#       sekarang disimpan di config/olt_profiles.json
#       Gunakan menu "OLT Profile Manager" untuk manage multiple OLT
#
# File ini hanya untuk konfigurasi Telegram Bot.
# Untuk manage OLT, gunakan CLI menu atau edit olt_profiles.json
#
# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================

# Bot Token dari @BotFather di Telegram
# Cara mendapatkan:
# 1. Chat dengan @BotFather
# 2. Send: /newbot
# 3. Ikuti instruksi untuk buat bot
# 4. Copy token yang diberikan
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890

# User ID yang authorized untuk menggunakan bot
# Pisahkan dengan koma untuk multiple users
# Cara mendapatkan User ID:
# 1. Chat dengan @userinfobot di Telegram
# 2. Bot akan reply dengan User ID Anda
# Format: TELEGRAM_ADMIN_USERS=123456789,987654321,555666777
TELEGRAM_ADMIN_USERS=123456789,987654321

# ============================================
# PETUNJUK SETUP TELEGRAM BOT
# ============================================
#
# 1. Rename file ini menjadi .env (hapus .example)
# 2. Ganti nilai TELEGRAM_BOT_TOKEN dengan token Anda
# 3. Ganti nilai TELEGRAM_ADMIN_USERS dengan User ID Anda
# 4. Save file
# 5. Install library: pip install python-telegram-bot
# 6. Run bot: python telegram_bot.py
#
# IMPORTANT / PENTING:
# - Jangan commit .env ke git!
# - Simpan token dengan aman
# - Hanya share User ID ke orang yang dipercaya
# - Bot token adalah rahasia, jangan share!
#
